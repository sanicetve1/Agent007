LOAN_DB_HOST=localhost
LOAN_DB_PORT=5432
LOAN_DB_NAME=loan_db
LOAN_DB_USER=admin
LOAN_DB_PASSWORD=admin

# Agent mode: false = deterministic pipeline (tools in fixed order); true = autonomous ReAct agent
ENABLE_AUTONOMY=false
# Max tool steps in autonomous mode (stop and inform user if exceeded)
AGENT_MAX_STEPS=8

